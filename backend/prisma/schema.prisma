// ===========================================
// 🏥 CLINIC MANAGEMENT SYSTEM - DATABASE SCHEMA
// ===========================================
// Provider: Neon PostgreSQL
// ORM: Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================
// 👨‍⚕️ DOCTORS TABLE
// ===========================================
model Doctor {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  phone         String?
  specialty     String
  bio           String?   @db.Text
  avatar        String?
  isAvailable   Boolean   @default(true)
  
  appointments  Appointment[]
  medicalRecords MedicalRecord[]
  labResults    LabResult[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("doctors")
}

// ===========================================
// 👤 PATIENTS TABLE
// ===========================================
model Patient {
  id            String    @id @default(uuid())
  firstName     String
  lastName      String
  email         String    @unique
  phone         String
  dateOfBirth   DateTime?
  gender        String?
  address       String?   @db.Text
  bloodType     String?
  
  appointments  Appointment[]
  medicalRecords MedicalRecord[]
  invoices      Invoice[]
  labResults    LabResult[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("patients")
}

// ===========================================
// 📅 APPOINTMENTS TABLE
// ===========================================
model Appointment {
  id            String    @id @default(uuid())
  date          DateTime
  status        AppointmentStatus @default(SCHEDULED)
  notes         String?   @db.Text
  reason        String?
  
  doctorId      String
  doctor        Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  
  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  medicalRecord MedicalRecord?
  labResults    LabResult[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("appointments")
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ===========================================
// 📋 MEDICAL RECORDS TABLE
// ===========================================
model MedicalRecord {
  id            String    @id @default(uuid())
  diagnosis     String?   @db.Text
  prescription  String?   @db.Text
  notes         String?   @db.Text
  attachments   String[]
  
  appointmentId String    @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  
  doctorId      String
  doctor        Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  
  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("medical_records")
}

// ===========================================
// 💰 INVOICES TABLE
// ===========================================
model Invoice {
  id            String    @id @default(uuid())
  amount        Float
  description   String?   @db.Text
  status        InvoiceStatus @default(PENDING)
  dueDate       DateTime?
  
  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  appointmentId String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("invoices")
}

enum InvoiceStatus {
  PENDING
  PAID
  CANCELLED
  OVERDUE
}

// ===========================================
// 🔐 USERS TABLE (For Authentication)
// ===========================================
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  role          Role      @default(STAFF)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

enum Role {
  ADMIN
  DOCTOR
  STAFF
  LAB_TECH
}

// ===========================================
// 🧪 LAB TESTS TABLE (Test Types/Categories)
// ===========================================
model LabTest {
  id            String    @id @default(uuid())
  name          String
  code          String    @unique  // e.g., "CBC", "LIPID", "HBA1C"
  category      String    // e.g., "Blood", "Urine", "X-Ray", "MRI"
  description   String?   @db.Text
  price         Float
  unit          String?   // e.g., "mg/dL", "g/dL", "cells/μL"
  referenceRange String?  // e.g., "12-16" for Hemoglobin
  minRange      Float?    // e.g., 12.0
  maxRange      Float?    // e.g., 16.0
  isFasting     Boolean   @default(false)
  turnaroundTime Int?     // Hours to complete
  isActive      Boolean   @default(true)
  
  // Dynamic fields configuration (JSON for flexibility)
  // Example: [{"name": "Hemoglobin", "unit": "g/dL", "min": 12, "max": 16}]
  fields        Json?
  
  labResults    LabResult[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("lab_tests")
}

// ===========================================
// 📊 LAB RESULTS TABLE (Patient Test Results)
// ===========================================
model LabResult {
  id            String    @id @default(uuid())
  status        LabResultStatus @default(PENDING)
  
  // Test results (JSON for dynamic fields)
  // Example: {"Hemoglobin": 14.2, "WBC": 7.5, "RBC": 4.8}
  results       Json?
  
  notes         String?   @db.Text
  attachments   String[]  // URLs to PDF/Images
  
  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  
  testId        String
  test          LabTest   @relation(fields: [testId], references: [id], onDelete: Cascade)
  
  completedBy   String?
  doctor        Doctor?   @relation(fields: [completedBy], references: [id], onDelete: SetNull)
  
  orderedBy     String?   // Doctor who ordered the test
  collectedAt   DateTime? // Sample collection time
  completedAt   DateTime? // Result completion time
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("lab_results")
}

enum LabResultStatus {
  PENDING
  COLLECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  CRITICAL
}
