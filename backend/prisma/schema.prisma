// ===========================================
// 🧪 LAB MODULE - HL7-inspired Schema
// ===========================================

// Lab Test Catalog (Admin-managed)
model LabTest {
  id              String         @id @default(cuid())
  name            String
  code            String         @unique
  category        LabTestCategory
  price           Decimal
  unit            String?
  referenceRange  String?
  isFasting       Boolean        @default(false)
  turnaroundTime  Int            // hours
  description     String?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  labRequests     LabRequest[]
  labResults      LabResult[]

  @@index([code])
  @@index([category])
  @@index([isActive])
}

// Lab Request (Doctor creates)
model LabRequest {
  id            String            @id @default(cuid())
  patientId     String
  patient       Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId      String
  doctor        Doctor            @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  tests         LabTest[]         // Many-to-many via junction
  status        LabRequestStatus  @default(PENDING)
  priority      String            @default("NORMAL") // NORMAL, URGENT, STAT
  notes         String?
  requestedAt   DateTime          @default(now())
  completedAt   DateTime?
  
  // Relations
  labResults    LabResult[]       @relation("RequestResults")

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
}

// Lab Result (Lab Tech enters)
model LabResult {
  id              String          @id @default(cuid())
  patientId       String
  patient         Patient         @relation(fields: [patientId], references: [id])
  labTestId       String
  labTest         LabTest         @relation(fields: [labTestId], references: [id])
  requestId       String
  request         LabRequest      @relation(fields: [requestId], references: [id], name: "RequestResults")
  value           String
  unit            String?
  referenceRange  String?
  isAbnormal      Boolean         @default(false)
  status          LabResultStatus @default(PENDING) // PENDING, PRELIMINARY, FINAL, VERIFIED
  verifiedBy      String?
  verifiedAt      DateTime?
  technicianId    String?
  technician      LabTechnician?  @relation(fields: [technicianId], references: [id], name: "TechnicianResults")
  notes           String?
  printedAt       DateTime?
  sentToDoctorAt  DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([patientId])
  @@index([labTestId])
  @@index([requestId])
  @@index([status])
}

// Enums
enum LabTestCategory {
  BLOOD
  URINE
  XRAY
  ULTRASOUND
  MRI
  CT_SCAN
  PATHOLOGY
  MICROBIOLOGY
  OTHER
}

enum LabRequestStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum LabResultStatus {
  PENDING
  PRELIMINARY
  FINAL
  VERIFIED
}