# ===========================================
# 🖥️ SERVER CONFIGURATION
# ===========================================
PORT=5000
NODE_ENV=development

# ===========================================
# 🗄️ DATABASE (Neon PostgreSQL)
# ===========================================
# Format: postgresql://user:password@host:port/database?sslmode=require
# Get your connection string from: https://neon.tech
DATABASE_URL="postgresql://clinic_user:dummy_password_123@ep-cool-branch-123456.us-east-2.aws.neon.tech/clinic_db?sslmode=require"

# ===========================================
# 🔐 JWT AUTHENTICATION
# ===========================================
# Generate a random secret key (min 32 characters)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="clinic-management-super-secret-jwt-key-change-in-production-2024"
JWT_EXPIRE=7d

# ===========================================
# 📧 EMAIL SERVICE (Nodemailer - Gmail)
# ===========================================
# For Gmail: Use App Password, not your regular password
# Get App Password from: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=clinic.notifications.example@gmail.com
EMAIL_PASS="xxxx xxxx xxxx xxxx"

# ===========================================
# 🌐 FRONTEND URL
# ===========================================
# Local development
FRONTEND_URL=http://localhost:5173
# Production (update after deployment)
# FRONTEND_URL=https://your-clinic-frontend.onrender.com

# ===========================================
# 🔒 SECURITY
# ===========================================
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# 📅 APPOINTMENT REMINDERS (Cron)
# ===========================================
REMINDER_CRON_SCHEDULE=0 9 * * *
