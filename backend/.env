# ===========================================
# 🖥️ Server Configuration
# ===========================================
PORT=5000
NODE_ENV=development

# ===========================================
# 🗄️ Database (Neon PostgreSQL)
# ===========================================
# ⚠️ استبدل هذا الرابط برابط قاعدة بياناتك من Neon.tech
DATABASE_URL="postgresql://user:password@ep-xyz.region.aws.neon.tech/neondb?sslmode=require"

# ===========================================
# 🔐 JWT Authentication
# ===========================================
# ⚠️ غيّر هذه القيمة إلى نص عشوائي طويل وقوي
JWT_SECRET="clinic-super-secret-jwt-key-2024-change-me"
JWT_EXPIRE=7d

# ===========================================
# 📧 Email Service (Nodemailer)
# ===========================================
# ⚠️ استخدم Gmail مع App Password أو خدمة أخرى
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-here

# ===========================================
# 🌐 Frontend URL
# ===========================================
FRONTEND_URL=http://localhost:5173

# ===========================================
# 🔒 Security
# ===========================================
BCRYPT_ROUNDS=10
